.btneeee {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.container-about {
  width: 100%;
  display: flex;
  gap: 15%;
  max-width: 1200px;
  position: absolute;
  top: 60%;
  left: 48%;
  height: 100vh;
  transform: translate(-50%, -50%);
  align-items: center;
  padding: 0 2rem;
}

/* ── photo side ── */
.photo {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.photo-wrapper {
  position: relative;
  width: 280px;
  height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* spinning border */
.photo-wrapper::before {
  content: '';
  position: absolute;
  inset: -2px;
  border-radius: 18px;
  background: conic-gradient(from var(--photo-angle, 0deg),
      transparent 0deg,
      #7c3aed 60deg,
      #db2777 130deg,
      #38bdf8 200deg,
      transparent 260deg);
  animation: photo-border-spin 4s linear infinite;
  z-index: 0;
}

/* dark fill behind image */
.photo-wrapper::after {
  content: '';
  position: absolute;
  inset: 2px;
  border-radius: 15px;
  background: #0a0a1a;
  z-index: 1;
}

/* glow blur behind photo */
.photo-glow {
  position: absolute;
  inset: -20px;
  border-radius: 24px;
  background: conic-gradient(from var(--photo-angle, 0deg),
      transparent 0deg,
      #7c3aed 60deg,
      #db2777 130deg,
      #38bdf8 200deg,
      transparent 260deg);
  animation: photo-border-spin 4s linear infinite;
  filter: blur(18px);
  opacity: 0.5;
  z-index: -1;
}

@property --photo-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}

@keyframes photo-border-spin {
  from {
    --photo-angle: 0deg;
  }

  to {
    --photo-angle: 360deg;
  }
}

.photo-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 14px;
  position: relative;
  z-index: 2;
}

/* ── about info box ── */
.about-info {
  width: 100vh;
  height: 100vh;
  margin-bottom: 70px;
  color: white;
  padding: 7px 44px;
  position: relative;
  border-radius: 5px;

  /* backdrop-filter: blur(10px); */
}

